{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.aicourt/corpus.schema.json",
  "title": "Unified strategy-disposition episode",
  "type": "object",
  "additionalProperties": true,
  "required": ["episode_id", "env", "env_version", "generator_model", "created_at", "players", "turns", "outcome"],
  "properties": {
    "episode_id": { "type": "string", "format": "uuid" },
    "env": { "type": "string", "minLength": 1 },
    "env_version": { "type": "string", "minLength": 1 },
    "generator_model": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "players": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["seat", "agent_id", "disposition", "disposition_prompt_id", "hidden_win_condition"],
        "properties": {
          "seat": { "type": "string", "minLength": 1 },
          "agent_id": { "type": "string", "minLength": 1 },
          "disposition": { "enum": ["machiavellian", "coalition", "neutral"] },
          "disposition_prompt_id": { "type": "string", "minLength": 1 },
          "hidden_win_condition": { "type": "string" },
          "archetype": { "type": ["string", "null"], "enum": ["broker", "auditor", "veto_holder", "guarantor", null] },
          "archetype_brief": { "type": ["object", "null"] }
          ,"generator_model": { "type": "string", "minLength": 1 }
          ,"reasoning_effort": { "enum": ["medium", "high", "xhigh"] }
          ,"assignment_cell_id": { "type": "string" }
          ,"disposition_assignment_source": { "type": "string" }
        }
      }
    },
    "turns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["turn", "events"],
        "properties": {
          "turn": { "type": "integer", "minimum": 1 },
          "events": {
            "type": "array",
            "items": { "$ref": "#/$defs/event" }
          }
        }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": true,
      "required": ["winner_seats", "win_type", "won_via_betrayal", "commitments_summary"],
      "properties": {
        "winner_seats": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "win_type": { "type": "string", "minLength": 1 },
        "won_via_betrayal": { "type": "boolean" },
        "commitments_summary": {
          "type": "object",
          "required": ["per_seat"],
          "properties": {
            "per_seat": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "required": ["made", "honored", "broken"],
                "properties": {
                  "made": { "type": "integer", "minimum": 0 },
                  "honored": { "type": "integer", "minimum": 0 },
                  "broken": { "type": "integer", "minimum": 0 }
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "event": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": true,
          "required": ["type", "from", "text"],
          "properties": { "type": { "const": "public_message" }, "from": { "type": "string" }, "text": { "type": "string" } }
        },
        {
          "type": "object",
          "additionalProperties": true,
          "required": ["type", "from", "to", "text"],
          "properties": { "type": { "const": "private_message" }, "from": { "type": "string" }, "to": { "type": "string" }, "text": { "type": "string" } }
        },
        {
          "type": "object",
          "additionalProperties": true,
          "required": ["type", "actor", "action"],
          "properties": { "type": { "const": "action" }, "actor": { "type": "string" }, "action": {} }
        },
        {
          "type": "object",
          "additionalProperties": true,
          "required": ["type", "id", "from", "to", "content", "kind", "deadline_turn"],
          "properties": {
            "type": { "const": "commitment" },
            "id": { "type": "string", "minLength": 1 },
            "from": { "type": "string" },
            "to": { "type": "string" },
            "content": { "type": "string", "minLength": 1 },
            "kind": { "enum": ["support", "non_aggression", "information", "resource", "marriage", "vote"] },
            "deadline_turn": { "type": "integer", "minimum": 1 }
          }
        },
        {
          "type": "object",
          "additionalProperties": true,
          "required": ["type", "commitment_id", "resolution", "evidence"],
          "properties": {
            "type": { "const": "commitment_resolution" },
            "commitment_id": { "type": "string", "minLength": 1 },
            "resolution": { "enum": ["honored", "broken", "expired", "superseded"] },
            "evidence": { "type": "string", "minLength": 1 }
          }
        }
      ]
    }
  }
}
